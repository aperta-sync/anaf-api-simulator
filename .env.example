# Core Server Settings
ANAF_MOCK_PORT=3003
ANAF_MOCK_STORE=memory # Set to 'redis' to use a persistent store
ANAF_MOCK_VERSION=0.5.0

# Simulation Settings
ANAF_MOCK_LATENCY_MS=200
ANAF_MOCK_ERROR_RATE=0
ANAF_MOCK_RATE_LIMIT_MODE=off # Options: 'off', 'deterministic', 'windowed'
ANAF_MOCK_STRICT_OWNERSHIP=true
ANAF_MOCK_STRICT_VAT=false
ANAF_MOCK_AUTO_TRAFFIC=false
ANAF_MOCK_PROCESSING_DELAY_MS=3000

# Redis Settings (Required if ANAF_MOCK_STORE=redis)
# REDIS_URL=redis://user:pass@host:port
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Bootstrap & Seeding
ANAF_MOCK_BOOTSTRAP_PRESET=anaf-core # Options: 'anaf-core', 'anaf-large', 'none'
# ANAF_MOCK_BOOTSTRAP_CUIS=RO123456,RO654321

# --- Scripts & Automation ---

# Discord Notifications (for ANAF scraper)
# ANAF_NOTIFIER_WEBHOOK=https://discord.com/api/webhooks/...

# Backblaze B2 / S3 Storage (for ANAF scraper large files)
# B2_BUCKET_NAME=my-anaf-bucket
# B2_ACCESS_KEY_ID=your_key_id
# B2_SECRET_ACCESS_KEY=your_application_key
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# B2_REGION=us-east-005
